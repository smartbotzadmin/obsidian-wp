{
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "foreground",
					"color": "#333333",
					"name": "Foreground"
				},
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				},
				{
					"slug": "primary",
					"color": "#007cba",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#666666",
					"name": "Secondary"
				},
				{
					"slug": "tertiary",
					"color": "#f8f9fa",
					"name": "Tertiary"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Font",
					"slug": "system-font"
				}
			],
			"fontSizes": [
				{
					"size": "13px",
					"slug": "small"
				},
				{
					"size": "16px",
					"slug": "medium"
				},
				{
					"size": "20px",
					"slug": "large"
				},
				{
					"size": "36px",
					"slug": "x-large"
				}
			]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true,
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-font)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "2.5rem",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "2rem",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "1.75rem",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "1.5rem",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "1.25rem",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "1rem",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontSize": "1.5rem",
					"fontWeight": "600"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--foreground)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontSize": "0.875rem"
				},
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				}
			},
			"core/navigation": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--foreground)"
						},
						"typography": {
							"textDecoration": "none",
							"fontWeight": "500"
						}
					}
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--foreground)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontSize": "0.875rem"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"lineHeight": "1.7"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"width": "4px",
						"color": "var(--wp--preset--color--primary)"
					}
				},
				"spacing": {
					"padding": {
						"left": "1rem"
					}
				},
				"typography": {
					"fontStyle": "italic"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--tertiary)"
				},
				"spacing": {
					"padding": "1rem"
				},
				"typography": {
					"fontFamily": "'Courier New', monospace"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}